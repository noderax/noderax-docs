{
  "name": "noderax-docs",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "lint": "eslint",
    "typecheck": "fumadocs-mdx && next typegen && tsc --noEmit",
    "sync:openapi": "node ./scripts/sync-openapi.mjs",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.18.0",
    "clsx": "^2.1.1",
    "fumadocs-core": "^16.7.14",
    "fumadocs-mdx": "^14.2.13",
    "fumadocs-openapi": "^10.6.8",
    "fumadocs-ui": "^16.7.14",
    "lucide-react": "^0.542.0",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/mdx": "^2.0.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.81.0"
  }
}
